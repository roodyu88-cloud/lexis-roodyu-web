    "@tiptap/extension-text-align": "^3.26.1",
    "@tiptap/react": "^3.26.1",
    "@tiptap/starter-kit": "^3.26.1",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "next": "16.2.6",
    "next-auth": "^4.24.14",
    "react": "19.2.4",
